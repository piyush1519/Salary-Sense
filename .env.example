# ── Backend ─────────────────────────────────
PORT=5000
NODE_ENV=production

# MongoDB — set your Atlas URI here for cloud, or use docker-compose default for local
MONGO_URI=mongodb://admin:salarysense123@mongodb:27017/salarysense?authSource=admin

# JWT — change this to a long random secret in production
JWT_SECRET=salary-sense-super-secret-jwt-key-change-in-production-2026

# ML Service URL (docker-compose service name)
ML_SERVICE_URL=http://ml-service:8000

# Frontend origin allowed for CORS
FRONTEND_URL=http://localhost

# ── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_APP_NAME=Salary-Sense
